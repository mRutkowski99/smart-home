generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Home {
  id      Int     @id @default(autoincrement())
  lat     Float?
  lng     Float?
  city    String?
  zipCode String?
  rooms   Room[]
  users   User[]
}

model Room {
  id     Int     @id @default(autoincrement())
  name   String
  state  Boolean
  homeId Int
  home   Home    @relation(fields: [homeId], references: [id])
}

model User {
  id     Int    @id @default(autoincrement())
  name   String
  homeId Int
  home   Home   @relation(fields: [homeId], references: [id])
}
