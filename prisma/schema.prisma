generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model HomeSchema {
  id           String         @id @default(uuid())
  rooms        RoomSchema[]
  scenes       SceneSchema[]
  alarms       AlarmSchema[]
  SafetySchema SafetySchema[]
}

model RoomSchema {
  id        String  @id @default(uuid())
  name      String
  imgUrl    String
  favourite Boolean @default(false)

  home   HomeSchema? @relation(fields: [homeId], references: [id])
  homeId String

  @@unique([id, homeId])
}

model SceneSchema {
  id         String    @id @default(uuid())
  name       String
  active     Boolean   @default(false)
  cron       String?
  expireDate DateTime?
  favourite  Boolean   @default(false)

  Home   HomeSchema? @relation(fields: [homeId], references: [id])
  homeId String

  @@unique([id, homeId])
}

model AlarmSchema {
  id          String  @id @default(uuid())
  name        String
  active      Boolean
  defaulState Boolean

  Home      HomeSchema?      @relation(fields: [homeId], references: [id])
  homeId    String
  alarmLogs AlarmLogSchema[]

  @@unique([id, homeId])
}

model AlarmLogSchema {
  id          String    @id @default(uuid())
  danger      Boolean
  message     String
  createDate  DateTime
  confirmed   Boolean?
  confirmedAt DateTime?
  confirmedBy String?

  alarm   AlarmSchema @relation(fields: [alarmId], references: [id])
  alarmId String

  @@unique([id, alarmId])
}

model SafetySchema {
  id   String           @id @default(uuid())
  name String
  type SafetyDeviceEnum

  Home      HomeSchema  @relation(fields: [homeId], references: [id])
  homeId    String
  SafetyLog SafetyLog[]

  @@unique([id, homeId])
}

enum SafetyDeviceEnum {
  WaterLeakSensor
  COSensor
  SmokeSensor
}

model SafetyLog {
  id          String    @id @default(uuid())
  message     String
  createDate  DateTime
  confirmed   Boolean
  confirmedAt DateTime?
  confirmedBy String?

  safety   SafetySchema @relation(fields: [safetyId], references: [id])
  safetyId String

  @@unique([id, safetyId])
}
