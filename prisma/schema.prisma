generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----- HOMES -----

model HomeSchema {
  id           String         @id @default(uuid())
  rooms        RoomSchema[]
  scenes       SceneSchema[]
  alarms       AlarmSchema[]
  SafetySchema SafetySchema[]
}

// ----- ROOMS -----

model RoomSchema {
  id        String  @id @default(uuid())
  name      String
  imgUrl    String
  favourite Boolean @default(false)

  home   HomeSchema? @relation(fields: [homeId], references: [id])
  homeId String

  @@unique([id, homeId])
}

// ----- SCENES -----

model SceneSchema {
  id         String    @id @default(uuid())
  name       String
  active     Boolean   @default(false)
  cron       String?
  expireDate DateTime?
  favourite  Boolean   @default(false)

  Home   HomeSchema? @relation(fields: [homeId], references: [id])
  homeId String

  @@unique([id, homeId])
}

// ----- ALARMS -----

model AlarmSchema {
  id          String  @id @default(uuid())
  name        String
  active      Boolean
  defaulState Boolean

  Home      HomeSchema?      @relation(fields: [homeId], references: [id])
  homeId    String
  alarmLogs AlarmLogSchema[]

  @@unique([id, homeId])
}

model AlarmLogSchema {
  id          String    @id @default(uuid())
  danger      Boolean
  message     String
  createDate  DateTime
  confirmed   Boolean?
  confirmedAt DateTime?
  confirmedBy String?

  alarm   AlarmSchema @relation(fields: [alarmId], references: [id])
  alarmId String

  @@unique([id, alarmId])
}

// ----- SAFETY -----

enum SafetyDevice {
  WaterLeakSensor
  COSensor
  SmokeSensor
}

enum SafetyState {
  Ok
  Danger
  Disabled
}

model SafetySchema {
  id   String       @id @default(uuid())
  name String
  type SafetyDevice

  Home      HomeSchema  @relation(fields: [homeId], references: [id])
  homeId    String
  SafetyLog SafetyLog[]

  @@unique([id, homeId])
}

model SafetyLog {
  id          String      @id @default(uuid())
  message     String
  createDate  DateTime
  state       SafetyState
  confirmed   Boolean
  confirmedAt DateTime?
  confirmedBy String?

  safety   SafetySchema @relation(fields: [safetyId], references: [id])
  safetyId String

  @@unique([id, safetyId])
}
