generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----- HOMES -----

model HomeSchema {
  id           String         @id @default(uuid())
  rooms        RoomSchema[]
  scenes       SceneSchema[]
  alarms       AlarmSchema[]
  SafetySchema SafetySchema[]
}

// ----- ROOMS -----

model RoomSchema {
  id        String  @id @default(uuid())
  name      String
  imgUrl    String
  favourite Boolean @default(false)

  home                    HomeSchema?               @relation(fields: [homeId], references: [id])
  homeId                  String
  devices                 DeviceSchema[]
  TemperatureDeviceSchema TemperatureDeviceSchema[]

  @@unique([id, homeId])
}

// ----- SCENES -----

model SceneSchema {
  id         String    @id @default(uuid())
  name       String
  active     Boolean   @default(false)
  cron       String?
  expireDate DateTime?
  favourite  Boolean   @default(false)

  Home   HomeSchema? @relation(fields: [homeId], references: [id])
  homeId String

  @@unique([id, homeId])
}

// ----- DEVICE -----
enum DeviceType {
  Temperature
  Ventilation
  Lighting
  Sunblind
  PowerPlug
}

enum CommunicationType {
  Digtal
  Analog
  Wifi
}

model DeviceSchema {
  id                String            @id @default(uuid())
  name              String
  value             Int
  type              DeviceType
  address           String
  communicationType CommunicationType

  room   RoomSchema @relation(fields: [roomId], references: [id])
  roomId String

  @@unique([id, roomId])
}

model TemperatureDeviceSchema {
  id                String            @id @default(uuid())
  name              String
  value             Int
  state             Boolean
  heatingValue      Int
  coolingValue      Int
  address           String
  communicationType CommunicationType

  room   RoomSchema @relation(fields: [roomId], references: [id])
  roomId String

  @@unique([id, roomId])
}

// ----- ALARMS -----

model AlarmSchema {
  id          String  @id @default(uuid())
  name        String
  active      Boolean
  defaulState Boolean

  Home      HomeSchema?      @relation(fields: [homeId], references: [id])
  homeId    String
  alarmLogs AlarmLogSchema[]

  @@unique([id, homeId])
}

model AlarmLogSchema {
  id          String    @id @default(uuid())
  danger      Boolean
  message     String
  createDate  DateTime
  confirmed   Boolean?
  confirmedAt DateTime?
  confirmedBy String?

  alarm   AlarmSchema @relation(fields: [alarmId], references: [id])
  alarmId String

  @@unique([id, alarmId])
}

// ----- SAFETY -----

enum SafetyDeviceSchemaEnum {
  WaterLeakSensor
  COSensor
  SmokeSensor
}

enum SafetyStateSchemaEnum {
  Ok
  Danger
  Disabled
}

model SafetySchema {
  id   String                 @id @default(uuid())
  name String
  type SafetyDeviceSchemaEnum

  Home   HomeSchema        @relation(fields: [homeId], references: [id])
  homeId String
  logs   SafetyLogSchema[]

  @@unique([id, homeId])
}

model SafetyLogSchema {
  id          String                @id @default(uuid())
  message     String
  createDate  DateTime
  state       SafetyStateSchemaEnum
  confirmed   Boolean?
  confirmedAt DateTime?
  confirmedBy String?

  safety   SafetySchema @relation(fields: [safetyId], references: [id])
  safetyId String

  @@unique([id, safetyId])
}
