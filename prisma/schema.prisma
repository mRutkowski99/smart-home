generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model HomeSchema {
  id     String        @id @default(uuid())
  rooms  RoomSchema[]
  scenes SceneSchema[]
}

model RoomSchema {
  id        String  @id @default(uuid())
  name      String
  imgUrl    String
  favourite Boolean @default(false)

  home   HomeSchema? @relation(fields: [homeId], references: [id])
  homeId String?     @unique

  @@unique([id, homeId])
}

model SceneSchema {
  id         String    @id @default(uuid())
  name       String
  active     Boolean   @default(false)
  cron       String?
  expireDate DateTime?
  favourite  Boolean   @default(false)

  Home   HomeSchema? @relation(fields: [homeId], references: [id])
  homeId String?

  @@unique([id, homeId])
}
