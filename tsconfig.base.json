{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2017", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@smart-home/api/core/feature": ["libs/api/core/feature/src/index.ts"],
      "@smart-home/api/core/shared/pipes/validation": [
        "libs/api/core/shared/pipes/validation/src/index.ts"
      ],
      "@smart-home/api/core/shared/services/prisma-service": [
        "libs/api/core/shared/services/prisma-service/src/index.ts"
      ],
      "@smart-home/api/core/shared/services/waether-api": [
        "libs/api/core/shared/services/waether-api/src/index.ts"
      ],
      "@smart-home/mobile/home/feature": [
        "libs/mobile/home/feature/src/index.ts"
      ],
      "@smart-home/mobile/home/ui/notification": [
        "libs/mobile/home/ui/notification/src/index.ts"
      ],
      "@smart-home/mobile/home/ui/summary-silder": [
        "libs/mobile/home/ui/summary-silder/src/index.ts"
      ],
      "@smart-home/mobile/home/ui/welcome": [
        "libs/mobile/home/ui/welcome/src/index.ts"
      ],
      "@smart-home/mobile/shared/ui/nav": [
        "libs/mobile/shared/ui/nav/src/index.ts"
      ],
      "@smart-home/mobile/shared/utils": [
        "libs/mobile/shared/utils/src/index.ts"
      ],
      "@smart-home/mobile/shell/feature": [
        "libs/mobile/shell/feature/src/index.ts"
      ],
      "@smart-home/shared/utils": ["libs/shared/utils/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
